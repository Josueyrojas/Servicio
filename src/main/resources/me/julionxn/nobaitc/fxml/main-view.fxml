<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox stylesheets="@../css/modules.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="me.julionxn.nobaitc.ui.controllers.MainController">
   <children>
      <HBox fx:id="btnContainer" spacing="8.0" styleClass="modulesContainer">
         <VBox.margin>
            <Insets />
         </VBox.margin>
         <children>
            <Button fx:id="nonbpaBtn" mnemonicParsing="false" onAction="#loadNONBPAModule" styleClass="module-button" text="NONBPA" />
            <Button fx:id="aliasBtn" mnemonicParsing="false" onAction="#loadAliasModule" styleClass="module-button" text="Alias Structure" />
            <Button fx:id="otherBtn" disable="true" mnemonicParsing="false" styleClass="module-button" text="Others" />
         </children>
         <padding>
            <Insets left="8.0" right="8.0" top="8.0" />
         </padding>
      </HBox>
        <VBox fx:id="mainVBox" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-width: 0 1 0 0;" VBox.vgrow="ALWAYS" />
   </children>
</VBox>
